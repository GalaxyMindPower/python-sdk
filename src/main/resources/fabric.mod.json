{
  "schemaVersion": 1,
  "id": "improvedtransparency",
  "version": "${version}",
  "name": "Improved Transparency",
  "description": "An experimental mod that uses screen shaders to render weather, clouds, and particles behind translucent blocks and water. May impact GPU performance.",
  "authors": [
    "Blackbox"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/improvedtransparency/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.example.improvedtransparency.ImprovedTransparencyMod"
    ]
  },
  "mixins": [
    "improvedtransparency.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}